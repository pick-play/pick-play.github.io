    "ISFJ": { "title": "용감한 수호자", "emoji": "🛡️", "desc": "따뜻하고 헌신적인 수호자입니다. 주변 사람들을 세심하게 챙기며, 묵묵히 자신의 역할을 다하는 유형이에요. 겉으로는 조용하지만 내면에는 강한 의지와 사람들을 향한 깊은 애정이 있습니다.", "traits": ["헌신적", "따뜻함", "세심함", "겸손한", "인내심", "배려심", "성실함", "관찰력"], "strengths": ["타인의 필요를 세심하게 파악하는 능력", "높은 헌신성과 책임감", "안정적이고 따뜻한 분위기 조성", "뛰어난 기억력과 관찰력"], "weaknesses": ["자신의 감정을 억누르는 경향", "거절을 잘 못함", "변화를 두려워할 수 있음"], "famousPeople": ["비욘세", "앤 해서웨이", "이순신 장군"], "careers": ["간호사", "초등교사", "사회복지사", "상담사"], "color": "from-green-500 to-teal-600" },
    "INFJ": { "title": "선의의 옹호자", "emoji": "🌌", "desc": "이상주의적이면서도 단호한 성격의 소유자입니다. 깊은 통찰력으로 세상을 더 나은 곳으로 만들고자 하며, 강한 직관과 공감 능력을 가지고 있습니다. 겉으로는 조용하지만 내면에는 세상을 바꾸고 싶은 열정이 타오르고 있는 희귀한 유형입니다.", "traits": ["통찰력", "이상주의", "결단력", "창의적", "공감 능력", "독창적", "헌신적", "완벽주의"], "strengths": ["깊은 통찰력과 직관으로 본질을 꿰뚫음", "강한 신념과 가치관으로 타인에게 영감을 줌", "뛰어난 글쓰기와 표현 능력", "깊은 대화와 공감 능력"], "weaknesses": ["지나친 완벽주의 경향", "현실과 이상의 괴리에서 번아웃", "비판에 예민할 수 있음"], "famousPeople": ["마틴 루터 킹", "간디", "니콜 키드먼"], "careers": ["심리상담사", "작가", "교수", "비영리단체 활동가"], "color": "from-purple-600 to-indigo-700" },
    "INTJ": { "title": "용의주도한 전략가", "emoji": "🧠", "desc": "독립적이고 전략적인 사고의 소유자입니다. 높은 기준을 가지고 끊임없이 발전을 추구하며, 16가지 유형 중 가장 독립적이고 단호합니다. 복잡한 시스템을 이해하고 설계하는 데 탁월하며, 비효율을 참지 못하는 유형입니다.", "traits": ["전략적 사고", "독립적", "결단력", "지적 호기심", "완벽주의", "분석적", "효율 추구", "비전 제시"], "strengths": ["장기적 전략과 비전 수립 능력", "복잡한 문제를 체계적으로 해결", "높은 자기 동기부여와 독립성", "지식에 대한 끝없는 탐구심"], "weaknesses": ["타인의 감정에 둔감할 수 있음", "지나치게 높은 기준으로 인한 스트레스", "자신의 방식에 대한 고집"], "famousPeople": ["일론 머스크", "크리스토퍼 놀란", "미셸 오바마"], "careers": ["소프트웨어 아키텍트", "과학자", "투자 전략가", "대학교수"], "color": "from-indigo-600 to-blue-800" },
    "ISTP": { "title": "만능 재주꾼", "emoji": "🔧", "desc": "호기심 많고 실용적인 문제 해결사입니다. 손으로 직접 만지고 분석하며 세상을 이해하는 유형이에요. 위기 상황에서도 차분하게 대처하며, 효율적이고 논리적인 해결책을 빠르게 찾아냅니다.", "traits": ["분석적", "실용적", "적응력", "문제해결", "차분함", "독립적", "손재주", "모험심"], "strengths": ["위기 상황에서의 뛰어난 대처 능력", "실용적이고 효율적인 문제 해결", "빠른 상황 판단력과 적응력", "기계나 도구를 다루는 뛰어난 손재주"], "weaknesses": ["장기적 계획 수립이 어려움", "감정 표현이 서툴 수 있음", "쉽게 지루해할 수 있음"], "famousPeople": ["클린트 이스트우드", "마이클 조던", "톰 크루즈"], "careers": ["엔지니어", "파일럿", "외과의사", "소방관"], "color": "from-gray-500 to-zinc-700" },
    "ISFP": { "title": "호기심 많은 예술가", "emoji": "🎨", "desc": "유연하고 매력적인 예술가 기질의 소유자입니다. 현재를 즐기며, 자신만의 공간과 자유를 소중히 여기는 유형이에요. 겉으로는 조용하고 수줍어 보이지만, 내면에는 강한 가치관과 풍부한 감수성이 있습니다.", "traits": ["예술적", "온화함", "자유로움", "감수성", "유연함", "관찰력", "겸손함", "현재 지향"], "strengths": ["뛰어난 미적 감각과 예술적 표현력", "타인을 있는 그대로 수용하는 포용력", "현재 순간을 충분히 즐기는 능력", "행동으로 보여주는 따뜻한 마음"], "weaknesses": ["장기적 계획 세우기를 어려워함", "비판에 쉽게 상처받음", "자기 주장을 잘 못함"], "famousPeople": ["밥 로스", "마이클 잭슨", "방탄소년단 뷔"], "careers": ["디자이너", "요리사", "수의사", "플로리스트"], "color": "from-rose-400 to-pink-600" },
    "INFP": { "title": "열정적인 중재자", "emoji": "🦋", "desc": "이상적인 세상을 꿈꾸는 낭만가입니다. 깊은 내면의 가치관을 가지고 진정성 있는 삶을 살아가며, 풍부한 상상력과 공감 능력의 소유자예요. 자신만의 세계가 풍부하고, 글이나 예술로 감정을 표현하는 것에 재능이 있습니다.", "traits": ["이상주의", "공감 능력", "창의적", "열정적", "진정성", "상상력", "치유자", "내면 지향"], "strengths": ["깊은 공감 능력과 감성 지능", "풍부한 상상력과 창의성", "진정성 있는 인간관계 구축", "글쓰기와 예술적 표현 능력"], "weaknesses": ["현실적인 일처리가 어려울 수 있음", "비판에 매우 예민함", "이상과 현실의 괴리에 좌절할 수 있음"], "famousPeople": ["윌리엄 셰익스피어", "J.R.R. 톨킨", "방탄소년단 RM"], "careers": ["작가", "심리상담사", "일러스트레이터", "음악가"], "color": "from-violet-400 to-purple-600" },
    "INTP": { "title": "논리적인 사색가", "emoji": "🔬", "desc": "끝없는 지적 호기심의 소유자입니다. 복잡한 이론과 아이디어를 분석하고 탐구하는 것을 즐기며, 논리적 사고에 매우 능합니다. 조용하고 과묵하지만, 관심 분야에서는 전문가 이상의 열정을 보여줍니다.", "traits": ["분석적", "독창적", "논리적", "탐구심", "객관적", "호기심", "이론적", "독립적"], "strengths": ["뛰어난 논리적 분석 능력", "독창적이고 혁신적인 아이디어", "복잡한 개념을 쉽게 이해하는 능력", "객관적이고 공정한 판단력"], "weaknesses": ["실행력이 부족할 수 있음", "감정적 교류가 어려움", "완벽한 이론을 추구하다 행동이 늦어짐"], "famousPeople": ["아인슈타인", "빌 게이츠", "래리 페이지"], "careers": ["소프트웨어 개발자", "데이터 과학자", "철학자", "수학자"], "color": "from-cyan-500 to-blue-600" },
    "ESTP": { "title": "모험을 즐기는 사업가", "emoji": "🏄", "desc": "에너지 넘치는 모험가입니다! 지금 이 순간을 즐기며, 빠른 판단력으로 문제를 해결합니다. 위험을 두려워하지 않고 도전하는 대담한 성격으로, 어떤 상황에서든 적응하는 유연함을 가지고 있습니다.", "traits": ["대담함", "현실적", "직접 경험", "사교적", "유연한", "행동파", "순발력", "관찰력"], "strengths": ["뛰어난 위기 대처 능력과 순발력", "사교적이고 설득력 있는 커뮤니케이션", "현실적이고 실용적인 판단", "어떤 환경에서든 빠른 적응력"], "weaknesses": ["장기적 계획보다 즉흥적 행동을 선호", "규칙과 제약을 답답해함", "감정적 깊이가 부족할 수 있음"], "famousPeople": ["도널드 트럼프", "마돈나", "잭 니클라우스"], "careers": ["기업가", "영업전문가", "스포츠 선수", "응급구조사"], "color": "from-amber-500 to-orange-600" },
    "ESFP": { "title": "자유로운 영혼의 연예인", "emoji": "🎤", "desc": "사교적이고 활기찬 분위기 메이커입니다! 주변 사람들에게 즐거움을 주며, 순간을 최대한 즐기는 유형이에요. 어떤 자리든 화기애애한 분위기로 만드는 타고난 엔터테이너입니다.", "traits": ["사교적", "즉흥적", "낙관적", "활기찬", "재미추구", "관대함", "실용적", "표현력"], "strengths": ["뛰어난 사교성과 분위기 메이킹", "현재 순간을 즐기는 긍정적 에너지", "실용적이고 행동 지향적인 성격", "타인에 대한 관대함과 포용력"], "weaknesses": ["장기적 계획 수립이 어려움", "진지한 상황을 회피할 수 있음", "충동적인 소비 경향"], "famousPeople": ["마릴린 먼로", "엘튼 존", "싸이"], "careers": ["연예인", "이벤트 플래너", "여행 가이드", "인테리어 디자이너"], "color": "from-yellow-400 to-amber-500" },
    "ENFP": { "title": "재기발랄한 활동가", "emoji": "🌈", "desc": "열정적이고 창의적인 자유로운 영혼입니다! 새로운 가능성을 발견하고, 사람들에게 영감을 주는 유형이에요. 끝없는 호기심과 따뜻한 마음으로 세상과 연결되며, 모든 사람에게서 장점을 발견하는 긍정의 아이콘입니다.", "traits": ["열정적", "창의적", "호기심", "공감 능력", "사교적", "영감 주는", "자유로운", "낙관적"], "strengths": ["뛰어난 아이디어와 창의적 사고", "사람들에게 영감과 동기를 부여하는 능력", "높은 공감 능력과 감성 지능", "어떤 상황에서든 가능성을 발견하는 낙관주의"], "weaknesses": ["관심사가 자주 바뀌어 마무리가 어려움", "감정 기복이 클 수 있음", "지나친 이상주의로 현실과 괴리"], "famousPeople": ["로빈 윌리엄스", "로버트 다우니 주니어", "월트 디즈니"], "careers": ["마케팅 전문가", "저널리스트", "창업가", "코치/멘토"], "color": "from-orange-400 to-pink-500" },
